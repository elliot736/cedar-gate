@startuml sequence-diagram
title cedar-gate — Request Lifecycle

actor Client
participant "Server" as srv
participant "Gateway" as gw
participant "EntityBuilder" as eb
participant "PolicyEvaluator" as pe
participant "AccessEvaluator" as ae
participant "PolicyRateLimiter" as rl
participant "Router" as rt
participant "Proxy" as px
database "Backend" as be
participant "MetricsRegistry" as met

Client -> srv : HTTP request
srv -> gw : dispatch(req, res)

gw -> gw : snapshot PolicyStore (policies + entities)
gw -> eb : buildPrincipal(req)
eb --> gw : principal EntityUid
gw -> eb : buildEndpointUID(method, path)
eb --> gw : resource EntityUid
gw -> eb : buildContext(req)
eb --> gw : Cedar context record

== Access Control ==

gw -> ae : evaluateAccess(principal, resource, context)
ae -> pe : evaluate(Action::access, principal, resource, context)
pe --> ae : EvaluationResult { decision, reasons }
alt denied
  ae --> gw : AccessResult { allowed: false, reasons }
  gw --> Client : 403 Forbidden
end
ae --> gw : AccessResult { allowed: true }

== Rate Limiting ==

gw -> rl : check(principal, resource, context)
rl -> pe : evaluate(Action::ratelimit, principal, resource, context)
pe --> rl : EvaluationResult (tier info)
rl -> rl : resolve tier → TokenBucket or SlidingWindow
rl -> rl : consume(key, config)
alt rate limited
  rl --> gw : RateLimitDecision { allowed: false, retryAfterMs }
  gw --> Client : 429 Too Many Requests
end
rl --> gw : RateLimitDecision { allowed: true, remaining }

== Routing ==

gw -> rt : resolveRoute(principal, resource, context)
rt -> pe : evaluate(Action::route, principal, resource, context)
pe --> rt : EvaluationResult (endpoint entity)
rt --> gw : ResolvedRoute { backend: { url, timeout } }

== Proxy ==

gw -> px : proxyRequest(req, backend)
px -> be : stream request
be --> px : stream response
px --> gw : GatewayResponse

gw -> met : record(duration, status, route)
gw --> srv : response
srv --> Client : HTTP response

@enduml
